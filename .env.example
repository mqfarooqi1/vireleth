# -----------------------------------------------------------------------------
# Nexus AI configuration
# Copy this file to ".env" (same folder) and fill in the values you want.
# Everything is optional — with NO key the app runs in a clickable demo mode.
# -----------------------------------------------------------------------------

# Your Claude API key. Get one at https://console.anthropic.com/  (Settings -> API keys)
# Leave blank to run in demo mode.
ANTHROPIC_API_KEY=

# Which Claude model to use. Options:
#   claude-haiku-4-5  -> cheapest & fastest
#   claude-sonnet-5   -> balanced
#   claude-opus-4-8   -> most capable (default)
ANTHROPIC_MODEL=claude-opus-4-8

# --- Branding (make it your own) ---------------------------------------------
BRAND=Vireleth
TAGLINE=Living intelligence · agentic, generative & predictive.
OWNER=our team

# --- Server ------------------------------------------------------------------
HOST=127.0.0.1
PORT=8000
MAX_TOKENS=4096
